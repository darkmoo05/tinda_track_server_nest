// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // In Prisma 7 the runtime URL is injected via the @prisma/adapter-pg adapter
  // in PrismaService. The CLI picks up DATABASE_URL from prisma.config.ts.
}

enum WalletProvider {
  GCASH
  MAYA
}

enum TransactionDirection {
  CASH_IN
  CASH_OUT
}

enum OcrStatus {
  PENDING
  COMPLETED
  FAILED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum StockMovementType {
  RESTOCK
  ADJUSTMENT
  SALE
}

// ─────────────────────────────────────────────────────────────────────────────
// CHARGE — tiered service-charge rules set by the owner.
// lowerBound / upperBound define the transaction amount range.
// chargeAmount is the fixed fee applied when the amount falls in that range.
// syncId mirrors the client-side UUID so offline devices can upsert safely.
// ─────────────────────────────────────────────────────────────────────────────
model Charge {
  id                  String   @id @default(uuid())
  syncId              String   @unique
  deviceId            String
  lowerBound          Float
  upperBound          Float
  chargeAmount        Float
  transactionTypeKey  String   @default("gcash_cashin")
  isDeleted           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("charges")
}

model Party {
  id            String   @id @default(uuid())
  syncId        String   @unique
  deviceId      String
  name          String
  accountNumber String
  entityId      String   @default("")
  description   String   @default("")
  joinDate      String
  isVerified    Boolean  @default(false)
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("parties")
}

model TransactionType {
  id           String   @id @default(uuid())
  syncId       String   @unique
  deviceId     String
  name         String
  isOutflow    Boolean  @default(false)
  walletAccount String  @default("GCash")
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("transaction_types")
}

model MovementCategory {
  id         String   @id @default(uuid())
  syncId     String   @unique
  deviceId   String
  name       String
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("movement_categories")
}

// ─────────────────────────────────────────────────────────────────────────────
// FEE TRANSACTION — records the service fee collected on each transaction.
// relatedTransactionSyncId links back to the ledger entry via its syncId.
// feeType mirrors the transaction title (e.g. "GCash Cash In").
// chargeDestination is the account where the fee income lands.
// ─────────────────────────────────────────────────────────────────────────────
model FeeTransaction {
  id                       String   @id @default(uuid())
  syncId                   String   @unique
  deviceId                 String
  relatedTransactionSyncId String?
  feeAmount                Float
  feeType                  String
  chargeDestination        String
  isDeleted                Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("fee_transactions")
}

model LedgerEntry {
  id                String   @id @default(uuid())
  syncId            String   @unique
  transactionId     String?
  deviceId          String
  entryType         String
  title             String   @default("")
  note              String   @default("")
  reference         String   @default("")
  amount            Float
  walletDelta       Float    @default(0)
  mayaWalletDelta   Float    @default(0)
  onHandDelta       Float    @default(0)
  recordedFlow      Float    @default(0)
  tag               String   @default("")
  iconKey           String   @default("")
  walletAccount     String   @default("")
  ownerScope        String   @default("Business")
  ownerMovementType String?
  ownerCategory     String?
  ownerPartyName    String?
  ownerPartyAccount String?
  entryDate         String
  isDeleted         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  transaction       Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@map("ledger_entries")
}

model Transaction {
  id                 String               @id @default(uuid())
  syncId             String?              @unique
  deviceId           String?
  walletProvider     WalletProvider
  direction          TransactionDirection
  amount             Float
  chargeAmount       Float                @default(0)
  totalAmount        Float
  balanceBefore      Float
  balanceAfter       Float
  chargeLowerBound   Float?
  chargeUpperBound   Float?
  chargeHandling     String               @default("addOnTop")
  receiptImagePath   String?
  receiptOriginalName String?
  receiptMimeType    String?
  receiptUploadedAt  DateTime?
  ocrStatus          OcrStatus            @default(PENDING)
  ocrExtractedAmount Float?
  ocrRawText         String?
  ocrProcessedAt     DateTime?
  externalProvider   String?
  externalTransactionId String?
  note               String               @default("")
  reference          String               @default("")
  entryDate          String
  status             TransactionStatus    @default(COMPLETED)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  ledgerEntries      LedgerEntry[]

  @@map("transactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCT CATEGORY — user-managed lookup table for product classification.
// `description` and `examples` populate the in-app management UI; the
// `isQuickAccess` flag pins up to 10 categories to the dashboard chip row.
// Synced from device to server via POST /inventory/categories/push.
// ─────────────────────────────────────────────────────────────────────────────
model ProductCategory {
  id            String    @id @default(uuid())
  syncId        String    @unique
  name          String    @unique
  description   String?   @default("")
  examples      String?   @default("")
  isQuickAccess Boolean   @default(false)
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  products      Product[]

  @@map("product_categories")
}

// ─────────────────────────────────────────────────────────────────────────────
// SHELF LOCATION — user-managed store zone / placement lookup table.
// `imageUrl` is set after a successful PATCH /:id/image upload via the
// global IStorageProvider; the local Flutter cache keeps the original
// `image_path` so the UI can show the picture even while offline.
// Synced from device to server via POST /inventory/shelf-locations/push.
// ─────────────────────────────────────────────────────────────────────────────
model ShelfLocation {
  id          String    @id @default(uuid())
  syncId      String    @unique
  name        String    @unique
  description String?   @default("")
  examples    String?   @default("")
  imageUrl    String?
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("shelf_locations")
}

model Product {
  id                String           @id @default(uuid())
  syncId            String?          @unique
  deviceId          String?
  name              String
  sku               String           @unique
  description       String           @default("")
  // Denormalized name snapshot — always kept in sync with the relation.
  category          String           @default("General")
  baseUnit          String           @default("pcs")
  costPrice         Float            @default(0)
  sellingPrice      Float
  stockInBaseUnit   Float            @default(0)
  reorderPoint      Int              @default(0)
  isActive          Boolean          @default(true)
  isDeleted         Boolean          @default(false)
  imageUrl          String?
  // Denormalized name snapshot — always kept in sync with the relation.
  shelfLocation     String?          @default("Counter")
  expirationDate    DateTime?
  // Optional FK relations — nullable so legacy products without a managed
  // category/location row are never broken.
  categoryId        String?
  shelfLocationId   String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  productCategory   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  shelfLocationRef  ShelfLocation?   @relation(fields: [shelfLocationId], references: [id], onDelete: SetNull)
  unitConversions   ProductUnitConversion[]
  saleItems         SaleItem[]
  stockMovements    StockMovement[]

  @@map("products")
}

model StockMovement {
  id               String            @id @default(uuid())
  productId        String
  movementType     StockMovementType
  quantity         Float
  previousQuantity Float
  newQuantity      Float
  note             String            @default("")
  reference        String            @default("")
  expirationDate   DateTime?
  createdAt        DateTime          @default(now())
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@map("stock_movements")
}

model ProductUnitConversion {
  id               String   @id @default(uuid())
  syncId           String   @unique
  productId        String
  unitName         String
  conversionFactor Float
  costPrice        Decimal  @db.Decimal(12, 2)
  sellingPrice     Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_unit_conversions")
}

model Sale {
  id             String     @id @default(uuid())
  reference      String     @unique
  deviceId       String?
  note           String     @default("")
  subtotal       Float
  totalAmount    Float
  paidAmount     Float
  changeAmount   Float      @default(0)
  totalItems     Int
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  saleItems      SaleItem[]

  @@map("sales")
}

model SaleItem {
  id         String   @id @default(uuid())
  saleId     String
  productId  String
  selectedUnit String
  quantity   Float
  unitPrice  Decimal  @db.Decimal(12, 2)
  computedBaseQuantity Float
  lineTotal  Float
  createdAt  DateTime @default(now())
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Customer {
  id          String        @id @default(uuid())
  name        String
  phone       String        @default("")
  address     String        @default("")
  notes       String        @default("")
  isDeleted   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  utangRecords UtangRecord[]

  @@map("customers")
}

model UtangRecord {
  id          String    @id @default(uuid())
  customerId  String
  description String    @default("")
  amount      Float
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@map("utang_records")
}
